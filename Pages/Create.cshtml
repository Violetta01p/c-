@page
@model C_.Pages.CreateModel

<h2>Створити новий продукт</h2>

<form method="post">
    <p>Назва: <input asp-for="NewProduct.Name" required /></p>
    <p>Ціна: <input asp-for="NewProduct.Price" type="number" step="0.01" required /></p>
    <p>Бренд ID: <input asp-for="NewProduct.BrandId" type="number" /></p>
    
    <button type="submit">Зберегти</button>
</form>

<a asp-page="Index">Повернутися назад</a>
