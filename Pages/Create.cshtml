@page
@model C_.Pages.CreateModel

<h2>Створити новий продукт</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" style="color: red;"></div>

    <p>
        Назва: <input asp-for="NewProduct.Name" />
        <span asp-validation-for="NewProduct.Name" style="color: red; font-size: 12px;"></span>
    </p>
    <p>
        Ціна: <input asp-for="NewProduct.Price" type="number" step="0.01" />
        <span asp-validation-for="NewProduct.Price" style="color: red; font-size: 12px;"></span>
    </p>
    <p>
        Бренд ID: <input asp-for="NewProduct.BrandId" type="number" />
        <span asp-validation-for="NewProduct.BrandId" style="color: red; font-size: 12px;"></span>
    </p>
    
    <button type="submit">Зберегти</button>
</form>

<a asp-page="Index">Повернутися назад</a>